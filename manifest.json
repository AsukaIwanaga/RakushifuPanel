{
  "manifest_version": 3,
  "name": "らくしふ 客数予測パネル",
  "version": "2.3.0",
  "description": "らくしふ編集画面に時間帯別客数予測シート（LE/REQ/LABOR%）・当日のタスクを表示し、シフト未確定日を監視する。シートIDなどは設定画面から店舗ごとに設定",
  "permissions": ["storage"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://sken-rakushifu-mg.go.akamai-access.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://sken-rakushifu-mg.go.akamai-access.com/admin/v2/schedules*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sken-rakushifu-mg.go.akamai-access.com/admin/v2/schedules*"],
      "js": ["page_hook.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
